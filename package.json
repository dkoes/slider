{
  "name": "slider",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "preview": "node scripts/preview.js",
    "proxy": "node scripts/cors-proxy.js",
    "agent": "python3 build/slider_agent.py",
    "agent:src": "python3 scripts/slider_agent.py",
    "dev": "nodemon --watch src --watch scripts/build.js --watch scripts/slider_agent.py --watch slider_config.json --ext ts,css,html,js,py,json --exec \"npm run build && python3 build/slider_agent.py\""
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pdfjs-dist": "^3.11.174",
    "typescript": "^5.8.3"
  }
}
